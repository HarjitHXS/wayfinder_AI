{
  "name": "wayfinder-ai",
  "version": "1.0.0",
  "description": "Wayfinder AI - Intelligent Web Automation Agent (Nx Monorepo)",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "backend": "nx serve backend",
    "frontend": "nx serve frontend",
    "dev": "nx run-many --target=serve --projects=backend,frontend --parallel",
    "build": "nx run-many --target=build --all",
    "build:backend": "nx build backend",
    "build:frontend": "nx build frontend",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "graph": "nx graph",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "postinstall": "node -e \"try{require('./.husky/install')}catch(e){}\""
  },
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "@google-cloud/vertexai": "^1.0.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^12.1.0",
    "playwright": "^1.41.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@nx/angular": "^18.0.0",
    "@nx/eslint": "^18.0.0",
    "@nx/eslint-plugin": "^18.0.0",
    "@nx/js": "^18.0.0",
    "@nx/node": "^18.0.0",
    "@nx/workspace": "^18.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.20",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nx": "^18.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "~5.2.0"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
