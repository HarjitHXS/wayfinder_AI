# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=autosteer
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./.gcp-key.json

# Gemini Model Configuration
# Using Vertex AI with $1,000 credit from GCP billing
# This will use the paid tier quotas (much higher limits)
# GOOGLE_AI_API_KEY is commented out to use Vertex AI
# GOOGLE_AI_API_KEY=YOUR_FREE_API_KEY_HERE

# Vertex AI Configuration
GEMINI_MODEL=gemini-2.0-flash

# Server Configuration
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
