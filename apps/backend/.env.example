# ⚠️ SECURITY WARNING: Never commit the .env file with actual credentials!
# Copy this to .env and update with your actual values

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=your-project-id-here
GOOGLE_CLOUD_REGION=us-central1

# SECURITY: Store credentials securely
# Option 1: File path (ensure file is in .gitignore)
GOOGLE_APPLICATION_CREDENTIALS=./.gcp-key.json
# Option 2: JSON string (better for containers, use secrets manager)
# GOOGLE_APPLICATION_CREDENTIALS='{"type":"service_account",...}'

# Gemini Model Configuration
GEMINI_MODEL=gemini-2.0-flash-exp

# Server Configuration
BACKEND_PORT=3001

# Frontend Configuration - CRITICAL for CORS security
FRONTEND_URL=http://localhost:3000
# In production, specify allowed origins (comma-separated):
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Node Environment - IMPORTANT for security!
NODE_ENV=development  # Set to "production" for prod deployment

# Firebase Admin SDK (Optional - for authentication)
# Store as JSON string - NEVER commit actual values!
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...",...}'

# Security Best Practices:
# ✓ Use environment-specific .env files (.env.development, .env.production)
# ✓ Use Cloud Secret Manager or AWS Secrets Manager in production
# ✓ Rotate credentials regularly (every 90 days recommended)
# ✓ Use service accounts with minimal required permissions
# ✓ Never log credential values
# ✓ Always use HTTPS in production
# ✓ Enable monitoring and alerting
# ✓ Set up automated vulnerability scanning

